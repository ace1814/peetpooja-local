# ─── Firebase (required) ─────────────────────────────────────────────────────
# Create a project at https://console.firebase.google.com
# → Project Settings → Your apps → Add web app → copy the config below

VITE_FIREBASE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# ─── Platform Supabase (optional but recommended) ────────────────────────────
# A single Supabase project YOU own — stores a list of all users who sign up.
# Lets you see who's using the app from the Supabase dashboard.
# Create the table by running supabase/platform-migration.sql in your project.
# If you skip this, sign-up/sign-in still works — you just won't have the registry.

VITE_PLATFORM_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_PLATFORM_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9…
